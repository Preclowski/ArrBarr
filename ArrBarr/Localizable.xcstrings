    "See what's airing tonight, get notified about new grabs, and surface indexer issues before they become a problem.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieh, was heute Abend läuft, erhalte Benachrichtigungen zu neuen Grabs und entdecke Indexer-Probleme, bevor sie eines werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira qué se emite esta noche, recibe avisos de nuevas capturas y detecta problemas con indexadores antes de que se conviertan en un problema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voyez ce qui passe ce soir, recevez des notifications pour les nouvelles captures et anticipez les soucis d'indexeurs avant qu'ils ne deviennent un problème."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zobacz, co leci dziś wieczorem, otrzymuj powiadomienia o nowych pobraniach i wykrywaj problemy z indeksami zanim staną się kłopotem."
          }
        }
      }
    },
