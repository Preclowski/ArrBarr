    "Make it yours": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pass es dir an"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazlo tuyo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Personnalisez-le"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostosuj do siebie"
          }
        }
      }
    },
    "Reorder sections, hide what you don't need, tweak refresh intervals, and pick your language in Settings. Show only what matters to you.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sortiere Abschnitte um, blende aus, was du nicht brauchst, passe die Aktualisierungsintervalle an und wähle deine Sprache in den Einstellungen. Zeige nur, was für dich wichtig ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reordena secciones, oculta lo que no necesites, ajusta los intervalos de actualización y elige tu idioma en Ajustes. Muestra solo lo que te importa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réorganisez les sections, masquez ce dont vous n'avez pas besoin, ajustez les intervalles d'actualisation et choisissez votre langue dans Réglages. N'affichez que ce qui compte pour vous."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zmień kolejność sekcji, ukryj to, czego nie potrzebujesz, dostosuj częstotliwość odświeżania i wybierz język w ustawieniach. Pokazuj tylko to, co ważne."
          }
        }
      }
    },
    "Download clients (optional)": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Download-Clients (optional)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clientes de descarga (opcional)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clients de téléchargement (optionnel)"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Klienci pobierania (opcjonalnie)"
          }
        }
      }
    },
    "Add SABnzbd, qBittorrent, NZBGet, Transmission, rTorrent, or Deluge to pause and resume directly from the queue. Most features work fine without it — your arr already handles the heavy lifting.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge SABnzbd, qBittorrent, NZBGet, Transmission, rTorrent oder Deluge hinzu, um direkt aus der Warteschlange zu pausieren und fortzusetzen. Die meisten Funktionen laufen auch ohne — deine arr kümmert sich schon um die Hauptarbeit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade SABnzbd, qBittorrent, NZBGet, Transmission, rTorrent o Deluge para pausar y reanudar directamente desde la cola. La mayoría de funciones funcionan sin él: tu arr ya hace el trabajo pesado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez SABnzbd, qBittorrent, NZBGet, Transmission, rTorrent ou Deluge pour mettre en pause et reprendre directement depuis la file. La plupart des fonctions marchent sans — votre arr fait déjà le gros du travail."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj SABnzbd, qBittorrent, NZBGet, Transmission, rTorrent lub Deluge, aby pauzować i wznawiać prosto z kolejki. Większość funkcji działa bez tego — Twój arr zajmie się resztą."
          }
        }
      }
    },
    "Enjoying ArrBarr?": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gefällt dir ArrBarr?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
