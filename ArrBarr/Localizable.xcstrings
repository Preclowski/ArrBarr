    "Add your Radarr or Sonarr connection to get started.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge deine Radarr- oder Sonarr-Verbindung hinzu, um loszulegen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade tu conexión de Radarr o Sonarr para empezar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez votre connexion Radarr ou Sonarr pour commencer."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj połączenie z Radarrem lub Sonarrem, aby rozpocząć."
